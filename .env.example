# Shared
APP_ENV=development

# Backend
API_V1_PREFIX=/api
DB_ENGINE=sqlite
DB_NAME=projecthealth
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
APP_ENCRYPTION_KEY=replace-with-base64-url-safe-32-byte-key
GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL_TEXT=gemini-1.5-flash
GEMINI_MODEL_VISION=gemini-1.5-flash
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=replace-me
STORAGE_BACKEND=s3
STORAGE_ENDPOINT_URL=
FRONTEND_URL=http://localhost:3000
TIME_ZONE=UTC
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
