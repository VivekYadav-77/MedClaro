# Shared
APP_ENV=development
FREE_INTEGRATIONS_MODE=true

# Backend
API_V1_PREFIX=/api
DB_ENGINE=sqlite
DB_NAME=projecthealth
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
APP_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_API_KEY=replace-with-feature-gemini-key
GEMINI_API_KEY_EXTRACTION=replace-with-extraction-gemini-key
GEMINI_API_KEY_ANALYSIS=replace-with-analysis-gemini-key
GEMINI_API_KEY_CHAT=replace-with-chat-gemini-key
GEMINI_API_KEY_FEATURES=replace-with-feature-gemini-key
GEMINI_MODEL_TEXT=gemini-3.1-flash-lite-preview
GEMINI_MODEL_VISION=gemini-3.1-flash-lite-preview
GEMINI_MODEL_CHAT=gemini-3.1-flash-lite-preview
GEMINI_MODEL_FEATURES=gemini-3.1-flash-lite-preview

FRONTEND_URL=http://localhost:3000
TIME_ZONE=UTC
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
